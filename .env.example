# ===========================================
# DATABASE
# ===========================================
# Neon PostgreSQL connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=

# ===========================================
# APPLICATION
# ===========================================
# Base URL of the app (no trailing slash)
# Local: http://localhost:3000
# Production: https://petit-meme.io
VITE_SITE_URL=http://localhost:3000

# Copy paste this
TZ=UTC

# ===========================================
# AUTHENTICATION (Better Auth)
# ===========================================
# Secret key for session encryption (min 32 chars)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Twitter OAuth credentials
# Get from: https://developer.x.com/en/portal/projects
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# Discord OAuth credentials (optional)
# Get from: https://discord.com/developers/applications
# Redirect URI: {VITE_SITE_URL}/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ===========================================
# VIDEO (Bunny CDN)
# ===========================================
# Get from: https://dash.bunny.net/stream
BUNNY_ACCESS_KEY=
BUNNY_COLLECTION_ID=
BUNNY_TOKEN_AUTH_KEY=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_STORAGE_ZONE_NAME=

# Client-side variables for video embed and delivery
VITE_BUNNY_LIBRARY_ID=
VITE_BUNNY_HOSTNAME=

# ===========================================
# SEARCH (Algolia)
# ===========================================
# Get from: https://dashboard.algolia.com/
# Server-only (never exposed to browser)
ALGOLIA_ADMIN_KEY=

# Shared between server and client (VITE_ prefix = available in browser)
VITE_ALGOLIA_APP_ID=
VITE_ALGOLIA_SEARCH_KEY=
VITE_ALGOLIA_INDEX=

# ===========================================
# AI (Google Gemini)
# ===========================================
# Get from: https://ai.google.dev/
GEMINI_API_KEY=

# ===========================================
# AI SEARCH (Anthropic Claude)
# ===========================================
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===========================================
# EMAILS (Resend)
# ===========================================
# Resend API key (starts with re_)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# (Optional) Override all email recipients - for dev/testing
# Remove this in production
EMAIL_OVERRIDE_TO=

# (Optional) Override sender address - for dev/testing with Resend free domain
EMAIL_OVERRIDE_FROM=

# ===========================================
# PAYMENTS (Stripe)
# ===========================================
# Stripe secret key (starts with sk_)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe price IDs for premium subscription (starts with price_)
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# Stripe webhook secret (starts with whsec_)
# Run: stripe listen --forward-to localhost:3000/api/auth/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# ===========================================
# CRON JOBS (Vercel Crons)
# ===========================================
# Secret for authenticating cron requests (min 16 chars)
# Generate with: openssl rand -hex 32
# Required in production, optional locally (skips auth if absent)
CRON_SECRET=

# ===========================================
# ERROR MONITORING (Sentry)
# ===========================================
# Sentry DSN (public, safe to expose client-side)
# Get from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
VITE_SENTRY_DSN=

# Sentry auth token for source map uploads (build-time only)
# Get from: https://sentry.io/settings/auth-tokens/
# Also store in .env.sentry-build-plugin for local builds
SENTRY_AUTH_TOKEN=
