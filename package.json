{
  "name": "petit-meme",
  "version": "0.1.0",
  "private": true,
  "description": "Meme management and sharing platform with video support, premium subscriptions, and a TikTok-style reels experience.",
  "license": "UNLICENSED",
  "author": "Victor de la Fouchardiere",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "prisma:migrate:dev": "dotenv -e .env.development -- prisma migrate deploy",
    "prisma:migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "prisma:seed:dev": "npx vite-node --mode development prisma/seed.ts",
    "prisma:reset-db:dev": "dotenv -e .env.development -- prisma migrate reset",
    "postinstall": "prisma generate && paraglide-js compile --project ./project.inlang && node scripts/copy-ffmpeg.js",
    "lint": "tsc && oxlint",
    "lint:fix": "tsc && oxlint --fix && pnpm run format",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "email:dev": "email dev --dir src/emails --port 3001",
    "prepare": "husky"
  },
