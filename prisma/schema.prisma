
generator client {
  provider        = "prisma-client"
  previewFeatures = ["fullTextSearchPostgres"]
  output   = "../src/db/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum UserLocale {
  fr
  en
}

model UserBookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  memeId    String   @map("meme_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meme Meme @relation(fields: [memeId], references: [id], onDelete: Cascade)

  @@unique([userId, memeId])
  @@index([userId])
  @@index([memeId])
  @@index([createdAt])
  @@map("user_bookmark")
}

model Category {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  keywords  String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memes        MemeCategory[]
  translations CategoryTranslation[]

  @@index([createdAt])
  @@map("category")
}

model MemeCategory {
  memeId     String   @map("meme_id")
  categoryId String   @map("category_id")
  createdAt  DateTime @default(now()) @map("created_at")

  meme     Meme     @relation(fields: [memeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([memeId, categoryId])
  @@index([categoryId])
  @@map("meme_category")
}

model Video {
  id          Int    @id @default(autoincrement())
  meme        Meme?
  bunnyId     String @unique @map("bunny_id")
  duration    Int
  bunnyStatus Int    @default(0) @map("bunny_status")

  @@map("video")
}

enum MemeStatus {
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED

  @@map("meme_status")
}

enum MemeContentLocale {
  FR
  EN
  UNIVERSAL

  @@map("meme_content_locale")
}

model Meme {
  id            String         @id @default(cuid())
  title         String
  videoId       Int            @unique @map("video_id")
  viewCount     Int            @default(0) @map("view_count")
  shareCount    Int            @default(0) @map("share_count")
  downloadCount Int            @default(0) @map("download_count")
  tweetUrl      String?        @unique @map("tweet_url")
  description   String         @default("")
  keywords      String[]       @default([])
  contentLocale MemeContentLocale @default(FR) @map("content_locale")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  publishedAt   DateTime?      @map("published_at")
  video         Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  bookmarkedBy  UserBookmark[]
  categories    MemeCategory[]
  translations  MemeTranslation[]
  status        MemeStatus     @default(PUBLISHED)
  viewsDaily          MemeViewDaily[]
  actionsDaily        MemeActionDaily[]
  studioGenerations   StudioGeneration[]
  submissions         MemeSubmission[]

  @@index([status])
  @@index([status, viewCount])
  @@index([status, publishedAt])
  @@index([status, contentLocale])
  @@map("meme")
}

model MemeViewDaily {
  id        String   @id @default(cuid())
  memeId    String   @map("meme_id")
  viewerKey String   @map("viewer_key")
  day       DateTime
  watchMs   Int      @default(0) @map("watch_ms")
  createdAt DateTime @default(now()) @map("created_at")

  meme Meme @relation(fields: [memeId], references: [id], onDelete: Cascade)

  @@unique([memeId, viewerKey, day])
  @@index([memeId, day])
  @@index([viewerKey, day])
  @@index([day])
  @@map("meme_view_daily")
}

model MemeActionDaily {
  id     String   @id @default(cuid())
  memeId String   @map("meme_id")
  day    DateTime
  action String
  count  Int      @default(0)

  meme Meme @relation(fields: [memeId], references: [id], onDelete: Cascade)

  @@unique([memeId, day, action])
  @@index([day, action, memeId])
  @@map("meme_action_daily")
}

model User {
  id              String         @id
  name            String
  email           String         @unique
  emailVerified   Boolean        @map("email_verified")
  image           String?
  createdAt       DateTime       @map("created_at")
  updatedAt       DateTime       @map("updated_at")
  accounts        Account[]
  sessions        Session[]
  bookmarks       UserBookmark[]
  generationCount Int            @default(0) @map("generation_count")

  role       String?
  banned     Boolean?
  banReason  String?   @map("ban_reason")
  banExpires DateTime? @map("ban_expires")

  stripeCustomerId         String?   @map("stripe_customer_id")
  termsAcceptedAt          DateTime? @map("terms_accepted_at")
  privacyAcceptedAt        DateTime? @map("privacy_accepted_at")
  verificationReminderSent Boolean   @default(false) @map("verification_reminder_sent")
  isAnonymized             Boolean   @default(false) @map("is_anonymized")
  locale                   UserLocale @default(fr)

  studioGenerations StudioGeneration[]
  adminActions      AdminAuditLog[]    @relation("AdminActions")
  memeSubmissions   MemeSubmission[]
  aiSearchLogs      AiSearchLog[]

  @@index([createdAt])
  @@map("user")
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  action         String
  actingAdminId  String   @map("acting_admin_id")
  targetId       String   @map("target_id")
  targetType     String   @map("target_type")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  actingAdmin User @relation("AdminActions", fields: [actingAdminId], references: [id])

  @@index([actingAdminId])
  @@index([createdAt])
  @@map("admin_audit_log")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String? @map("impersonated_by")

  @@index([userId])
  @@map("session")
}

model Subscription {
  id                  String   @id
  plan                String
  referenceId         String   @map("reference_id")
  stripeCustomerId    String?  @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  status              String
  periodStart         DateTime? @map("period_start")
  periodEnd           DateTime? @map("period_end")
  cancelAtPeriodEnd   Boolean?  @map("cancel_at_period_end")
  seats               Int?
  trialStart          DateTime? @map("trial_start")
  trialEnd            DateTime? @map("trial_end")

  @@index([referenceId, status])
  @@index([status])
  @@map("subscription")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
}

model StudioGeneration {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  memeId    String?  @map("meme_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  meme Meme? @relation(fields: [memeId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([memeId, createdAt])
  @@map("studio_generation")
}

model RateLimit {
  id          String @id @default(cuid())
  key         String @unique
  count       Int
  lastRequest BigInt @map("last_request")
  windowStart BigInt @map("window_start")

  @@index([lastRequest])
  @@map("rate_limit")
}

enum MemeSubmissionUrlType {
  TWEET
  YOUTUBE

  @@map("meme_submission_url_type")
}

enum MemeSubmissionStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("meme_submission_status")
}

model MemeSubmission {
  id            String               @id @default(cuid())
  userId        String               @map("user_id")
  title         String
  url           String               @unique
  urlType       MemeSubmissionUrlType @map("url_type")
  contentLocale MemeContentLocale     @map("content_locale")
  status        MemeSubmissionStatus  @default(PENDING)
  adminNote     String?              @map("admin_note")
  memeId        String?              @map("meme_id")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  meme Meme? @relation(fields: [memeId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([userId, status])
  @@index([status, createdAt(sort: Desc)])
  @@map("meme_submission")
}

model MemeTranslation {
  id          String   @id @default(cuid())
  memeId      String   @map("meme_id")
  locale      String
  title       String
  description String   @default("")
  keywords    String[] @default([])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  meme Meme @relation(fields: [memeId], references: [id], onDelete: Cascade)

  @@unique([memeId, locale])
  @@map("meme_translation")
}

model CategoryTranslation {
  id         String   @id @default(cuid())
  categoryId String   @map("category_id")
  locale     String
  title      String
  keywords   String[] @default([])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translation")
}

model AiSearchLog {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  prompt         String
  query          String
  categorySlugs  String[] @map("category_slugs")
  memeIds        String[] @map("meme_ids")
  locale         UserLocale
  resultCount    Int      @map("result_count")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("ai_search_log")
}

model RecommendCache {
  key       String   @id
  data      Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("recommend_cache")
}
